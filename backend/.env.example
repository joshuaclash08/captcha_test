# ══════════════════════════════════════════════════════════════
# Noise CAPTCHA Production Configuration
# ══════════════════════════════════════════════════════════════
# Copy this file to .env and configure for your environment

# Server settings
PORT=3000
NODE_ENV=production

# CORS & Security
# Comma-separated list of allowed origins (domains that can embed the CAPTCHA)
ALLOWED_ORIGINS=https://example.com,https://app.example.com
# Set to "*" to allow all origins (NOT recommended for production)
# ALLOWED_ORIGINS=*

# Token expiry time in seconds (default: 120)
TOKEN_EXPIRY_SECONDS=120

# Rate limiting
# Requests per minute per IP for challenge endpoint
RATE_LIMIT_CHALLENGE=30
# Requests per minute per IP for verify endpoint
RATE_LIMIT_VERIFY=60

# Challenge settings
# Time-to-live for challenges in seconds (default: 60)
CHALLENGE_TTL_SECONDS=60
# Maximum verification attempts per challenge
MAX_ATTEMPTS=3

# AES Encryption keys (32 bytes each, hex encoded)
# IMPORTANT: Generate new keys for production!
# Example: openssl rand -hex 32
# If not set, uses default dev keys (NOT SECURE for production)
# AES_KEY_SEED=<64 hex chars>
# AES_KEY_MASK=<64 hex chars>
# Optional previous AES key pair for rotation window
# AES_KEY_SEED_PREV=<64 hex chars>
# AES_KEY_MASK_PREV=<64 hex chars>

# Redis connection (used for challenges, tokens, and rate limiting)
# If not set, defaults to redis://localhost:6379
# REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=
# REDIS_TLS=false

# ══════════════════════════════════════════════════════════════
# Site Registry Configuration (JSON file)
# ══════════════════════════════════════════════════════════════
# JSON file path for site registry (optional, absolute or relative to server root)
# SITE_REGISTRY_PATH=data/sites.json

# Auto-register demo site in development (set to false in production)
AUTO_REGISTER_DEMO_SITE=false

# Pre-register sites (format: name1:domain1,domain2;name2:domain3)
# CAPTCHA_SITES=MySite:example.com,*.example.com;AnotherSite:other.com

# Logging
LOG_LEVEL=info

# Debug mode (enables /debug endpoints - NEVER enable in production!)
DEBUG_MODE=false

# Risk scoring
RISK_SCORE_THRESHOLD=85
RISK_WINDOW_SECONDS=120

# Security audit JSONL behavior
ENABLE_SECURITY_AUDIT_LOG=true
# SECURITY_AUDIT_LOG_PATH=data/security-events.jsonl
SECURITY_AUDIT_DAILY_ROLLING=true
SECURITY_AUDIT_STRICT=false
# INSTANCE_ID=local
